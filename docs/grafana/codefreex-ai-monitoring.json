        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(ai_model_call_total{application=\"codefreex\", status=\"success\"}) / sum(ai_model_call_total{application=\"codefreex\"}) * 100",
